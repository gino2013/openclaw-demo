{
  "name": "@openclaw/gateway",
  "version": "0.1.0",
  "description": "WebSocket Gateway server for OpenClaw",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openclaw/core": "workspace:*",
    "ws": "^8.16.0",
    "express": "^4.18.0",
    "uuid": "^9.0.0",
    "pino": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
