# Gateway
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=your-secret-token-here

# Orchestrator
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_ORCHESTRATOR_TIMEOUT_MS=30000
OPENCLAW_ORCHESTRATOR_MAX_RETRIES=3

# Logging
LOG_LEVEL=info

# Office Frontend
NEXT_PUBLIC_GATEWAY_SSE_URL=http://localhost:18789/events
NEXT_PUBLIC_GATEWAY_REST_URL=http://localhost:18789
NEXT_PUBLIC_OFFICE_SCALE=4

# Optional: AI Provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
