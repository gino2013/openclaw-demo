{
  "name": "openclaw",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-Agent AI Collaboration Framework",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
